# ─── Django ───────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=cambia-esto-por-una-clave-secreta-muy-larga

# ─── Base de datos ────────────────────────────────────────────
DB_NAME=pos_saas
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
